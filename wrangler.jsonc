{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lcfc-book-value",
  "compatibility_date": "2026-07-13",
  "main": "src/index.js",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
